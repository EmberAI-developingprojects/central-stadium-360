# ----- Supabase (auth + Postgres) -----
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ----- Upstash Redis (sessions / rate limiting / ephemeral state) -----
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ----- AWS (S3 / MediaLive / MediaPackage for 360° stream segments) -----
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_MEDIAPACKAGE_CHANNEL_ID=

# ----- QPay (Mongolian payments) -----
QPAY_USERNAME=
QPAY_PASSWORD=
QPAY_INVOICE_CODE=
QPAY_BASE_URL=https://merchant.qpay.mn
# HMAC secret used to authenticate QPay's webhook callbacks
QPAY_CALLBACK_SECRET=
# Public, internet-reachable backend URL — needed so QPay can POST to us
PUBLIC_BACKEND_URL=

# ----- In-person kiosk -----
# Static device key the stadium kiosk sends as X-Kiosk-Key (long & random)
KIOSK_API_KEY=

# ----- Stream / playback -----
STREAM_BASE_URL=
SIGNED_URL_SECRET=

# ----- App config -----
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
JWT_SECRET=
