# Local dev
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# Extra CORS origins beyond FRONTEND_URL, comma-separated (optional)
# CORS_ALLOWED_ORIGINS=https://example.com,https://staging.example.com

# Supabase ───────────────────────────────────────────────────────────────
# Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# AWS (S3 / MediaLive / MediaPackage) ────────────────────────────────────
AWS_REGION=

# Wowza live camera HLS playback URLs (master .m3u8 per camera).
# Resolution order per camera: WOWZA_CAM{n}_URL -> AWS_IVS_CAM{n}_URL (legacy)
#   -> WOWZA_HLS_URL. For ONE feed on all four angles, set only WOWZA_HLS_URL.
# Wowza HLS URL format: https://<host>/<application>/<streamName>/playlist.m3u8
# Use HTTPS in production (http:// is blocked as mixed content on the https site).
WOWZA_HLS_URL=
WOWZA_CAM1_URL=
WOWZA_CAM2_URL=
WOWZA_CAM3_URL=
WOWZA_CAM4_URL=

# Wowza Video (Cloud) REST API — used by lib/recordings.ts to fetch
# recording download URLs after a live stream ends. Generate the JWT at
# app.wowza.com → Token Management. Stream IDs are shown in each Live
# Stream's Overview → ID.
WOWZA_JWT=
WSC_API_BASE=https://api.video.wowza.com/api/v2.0
WOWZA_CAM1_STREAM_ID=
WOWZA_CAM2_STREAM_ID=
WOWZA_CAM3_STREAM_ID=
WOWZA_CAM4_STREAM_ID=

# S3 bucket where Wowza VOD recordings are copied to (per event + camera).
AWS_IVS_RECORDINGS_BUCKET=

# CloudFront signing for VOD recordings (signs master.m3u8 + segments)
AWS_CLOUDFRONT_DOMAIN=
AWS_CLOUDFRONT_KEY_PAIR_ID=
AWS_CLOUDFRONT_PRIVATE_KEY_BASE64=

# QPay ───────────────────────────────────────────────────────────────────
QPAY_USERNAME=
QPAY_PASSWORD=
QPAY_INVOICE_CODE=
QPAY_BASE_URL=https://merchant.qpay.mn
# HMAC secret used to sign callback URLs (must be long & random)
QPAY_CALLBACK_SECRET=
# Public URL the QPay webhook can reach — overrides BACKEND_URL when set
PUBLIC_BACKEND_URL=

# In-person kiosk ─────────────────────────────────────────────────────────
# Static device key the stadium kiosk sends as X-Kiosk-Key (long & random).
# Lives on the kiosk box only — it is not a user credential.
KIOSK_API_KEY=

# Auth / signing
JWT_SECRET=
SIGNED_URL_SECRET=

SMS_PROVIDER=

CALLPRO_API_KEY=
CALLPRO_FROM=

SMS_HOOK_SECRET=

EMAIL_PROVIDER=

EMAIL_HOOK_SECRET=
