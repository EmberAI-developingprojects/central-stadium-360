# Local dev
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Supabase ───────────────────────────────────────────────────────────────
# Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Upstash Redis (rate-limits OTP/resend; optional in dev) ────────────────
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# AWS (S3 / MediaLive / MediaPackage) ────────────────────────────────────
AWS_REGION=

# AWS IVS live camera HLS playback URLs
AWS_IVS_CAM1_URL=
AWS_IVS_CAM2_URL=
AWS_IVS_CAM3_URL=
AWS_IVS_CAM4_URL=

AWS_IVS_CAM1_ARN=
AWS_IVS_CAM2_ARN=
AWS_IVS_CAM3_ARN=
AWS_IVS_CAM4_ARN=

# S3 bucket where IVS auto-records the four channels. Required for
# lazy VOD discovery (see lib/recordings.ts).
AWS_IVS_RECORDINGS_BUCKET=

IVS_PLAYBACK_KEY_ARN=
IVS_PRIVATE_KEY_BASE64=

# CloudFront signing for VOD recordings (signs master.m3u8 + segments)
AWS_CLOUDFRONT_DOMAIN=
AWS_CLOUDFRONT_KEY_PAIR_ID=
AWS_CLOUDFRONT_PRIVATE_KEY_BASE64=

# QPay ───────────────────────────────────────────────────────────────────
QPAY_USERNAME=
QPAY_PASSWORD=
QPAY_INVOICE_CODE=
QPAY_BASE_URL=https://merchant.qpay.mn
# HMAC secret used to sign callback URLs (must be long & random)
QPAY_CALLBACK_SECRET=
# Public URL the QPay webhook can reach — overrides BACKEND_URL when set
PUBLIC_BACKEND_URL=

# Auth / signing
JWT_SECRET=
SIGNED_URL_SECRET=

SMS_PROVIDER=

CALLPRO_API_KEY=
CALLPRO_FROM=

SMS_HOOK_SECRET=
