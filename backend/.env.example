# Local dev
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# Extra CORS origins beyond FRONTEND_URL, comma-separated (optional)
# CORS_ALLOWED_ORIGINS=https://example.com,https://staging.example.com

# Supabase ───────────────────────────────────────────────────────────────
# Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# AWS (S3 / MediaLive / MediaPackage) ────────────────────────────────────
AWS_REGION=

# Wowza live camera HLS playback URLs (master .m3u8 per camera).
# Resolution order per camera: WOWZA_CAM{n}_URL -> AWS_IVS_CAM{n}_URL (legacy)
#   -> WOWZA_HLS_URL. For ONE feed on all four angles, set only WOWZA_HLS_URL.
# Wowza HLS URL format: https://<host>/<application>/<streamName>/playlist.m3u8
# Use HTTPS in production (http:// is blocked as mixed content on the https site).
WOWZA_HLS_URL=
WOWZA_CAM1_URL=
WOWZA_CAM2_URL=
WOWZA_CAM3_URL=
WOWZA_CAM4_URL=

# Concurrent-device enforcement for ticket tiers (Standard=1, 3-User=3, 5-User=5).
# When "1", GET /api/watch/token requires a valid paid ticket for the event and
# admits the device against the ticket's max_devices, blocking the (N+1)th.
# Leave blank/0 to keep /token open (the live preview) until tickets are seeded.
WATCH_ENFORCE=

# Local dev-only: when "1", ticket purchase skips QPay and issues an
# immediately-PAID ticket (synthetic invoice id) so the buy→watch flow can be
# tested without a QPay merchant. NEVER set in production.
DEV_FAKE_PAY=

# ── Live stream URL signing (CloudFront) ───────────────────────────────────
# When "1", GET /api/watch/token returns CloudFront-SIGNED live camera URLs
# (minted only after the device is admitted), so a leaked .m3u8 link expires
# after LIVE_SIGN_TTL_SECONDS. Requires the cam{n}.stadium.mn CloudFront
# distributions to "Restrict viewer access" via a trusted key group containing
# the key below. Leave blank to serve raw (unsigned) URLs.
LIVE_SIGN_URLS=
# Signed-URL lifetime in seconds (default 21600 = 6h; long enough for an event
# session, short enough that a leaked link dies afterwards).
LIVE_SIGN_TTL_SECONDS=
# Key pair for signing live URLs. Falls back to AWS_CLOUDFRONT_KEY_PAIR_ID /
# AWS_CLOUDFRONT_PRIVATE_KEY_BASE64 (the VOD key) when unset — set these only if
# the cam distributions use a different CloudFront key group.
LIVE_CLOUDFRONT_KEY_PAIR_ID=
LIVE_CLOUDFRONT_PRIVATE_KEY_BASE64=

# Wowza Video (Cloud) REST API — used by lib/recordings.ts to fetch
# recording download URLs after a live stream ends. Generate the JWT at
# app.wowza.com → Token Management. Stream IDs are shown in each Live
# Stream's Overview → ID.
WOWZA_JWT=
WSC_API_BASE=https://api.video.wowza.com/api/v2.0
WOWZA_CAM1_STREAM_ID=
WOWZA_CAM2_STREAM_ID=
WOWZA_CAM3_STREAM_ID=
WOWZA_CAM4_STREAM_ID=

# S3 bucket where Wowza VOD recordings are copied to (per event + camera).
AWS_IVS_RECORDINGS_BUCKET=

# CloudFront signing for VOD recordings (signs master.m3u8 + segments)
AWS_CLOUDFRONT_DOMAIN=
AWS_CLOUDFRONT_KEY_PAIR_ID=
AWS_CLOUDFRONT_PRIVATE_KEY_BASE64=

# QPay ───────────────────────────────────────────────────────────────────
QPAY_USERNAME=
QPAY_PASSWORD=
QPAY_INVOICE_CODE=
QPAY_BASE_URL=https://merchant.qpay.mn
# HMAC secret used to sign callback URLs (must be long & random)
QPAY_CALLBACK_SECRET=
# Public URL the QPay webhook can reach — overrides BACKEND_URL when set
PUBLIC_BACKEND_URL=

# In-person kiosk ─────────────────────────────────────────────────────────
# Static device key the stadium kiosk sends as X-Kiosk-Key (long & random).
# Lives on the kiosk box only — it is not a user credential.
KIOSK_API_KEY=

# eBarimt PosAPI 3.0 ───────────────────────────────────────────────────────
# Local PosAPI service (runs on the merchant box) the card rail calls to issue
# a fiscal receipt (QR + lottery). Leave EBARIMT_POSAPI_URL blank to disable.
# Register a merchant once via <url>/web/ or every receipt returns ERROR.
EBARIMT_POSAPI_URL=http://127.0.0.1:7080
EBARIMT_MERCHANT_TIN=
EBARIMT_POS_NO=
# branchNo + districtCode (4-digit) come from YOUR registered eBarimt branch —
# set these from your merchant registration, not the test values below.
EBARIMT_BRANCH_NO=001
EBARIMT_DISTRICT_CODE=3420
# 7-digit classificationCode from the official unified catalog
# (https://ebarimt.mn — "Бүтээгдэхүүн, үйлчилгээний нэгдсэн ангилал"): pick the
# code your accountant registered for event/admission tickets. The value below
# is a PLACEHOLDER the staging rig accepts — confirm the real one before prod.
EBARIMT_CLASSIFICATION_CODE=6201200
# 3-digit taxProductCode — ONLY used for VAT_FREE / VAT_ZERO merchants; ignored
# for VAT_ABLE. Leave blank unless you sell VAT-exempt goods.
EBARIMT_TAX_PRODUCT_CODE=
EBARIMT_MEASURE_UNIT=sh
# 1 = VAT_ABLE (10% inclusive), 0 = VAT_FREE merchant.
EBARIMT_VAT=1
# Dev-only: route ONLINE 360-ticket receipts through the local PosAPI rig.
# Leave UNSET in prod — real QPay online payments get e-barimt from QPay's cloud
# (createEbarimt); the local PosAPI is reserved for the in-person/card rail.
EBARIMT_POSAPI_FOR_ONLINE=

# Auth / signing
JWT_SECRET=
SIGNED_URL_SECRET=

SMS_PROVIDER=

CALLPRO_API_KEY=
CALLPRO_FROM=

SMS_HOOK_SECRET=

EMAIL_PROVIDER=

EMAIL_HOOK_SECRET=
