# Local dev
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Supabase ───────────────────────────────────────────────────────────────
# Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Upstash Redis (rate-limits OTP/resend; optional in dev) ────────────────
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Supabase "Send SMS Hook" ───────────────────────────────────────────────
# Required if you have the hook configured in Supabase dashboard
# (Auth → Hooks → Send SMS Hook). Copy the secret shown in the dashboard
# verbatim — it looks like: v1,whsec_<base64>
SMS_HOOK_SECRET=

# SMS provider ───────────────────────────────────────────────────────────
# Leave SMS_PROVIDER unset (or "dev") to log OTPs to the backend console
# instead of sending real SMS — useful for local development.
# Set to "twilio", "mobicom", or "skytel" to dispatch real messages.
SMS_PROVIDER=

# Twilio (only when SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Mongolian aggregators — stubs in lib/sms.ts until carrier creds exist
MOBICOM_API_KEY=
MOBICOM_SENDER=
SKYTEL_API_KEY=
SKYTEL_SENDER=

# AWS (S3 / MediaLive / MediaPackage) ────────────────────────────────────
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_MEDIAPACKAGE_CHANNEL_ID=

# QPay ───────────────────────────────────────────────────────────────────
QPAY_USERNAME=
QPAY_PASSWORD=
QPAY_INVOICE_CODE=
QPAY_BASE_URL=https://merchant.qpay.mn
# HMAC secret used to sign callback URLs (must be long & random)
QPAY_CALLBACK_SECRET=
# Public URL the QPay webhook can reach — overrides BACKEND_URL when set
PUBLIC_BACKEND_URL=

# Auth / signing
JWT_SECRET=
SIGNED_URL_SECRET=
