# Dependencies
node_modules/
**/node_modules/

# Lock files — pnpm only (never commit npm/yarn lock)
package-lock.json
**/package-lock.json
yarn.lock
**/yarn.lock

# Build output
dist/
build/
.vite/

# Environment + secrets
.env
.env.*
!.env.example
*.pem

# Editor / OS noise
.DS_Store
Thumbs.db
*.log
.idea/
.vscode/

# Local agent state
.claude/

# TinyMCE self-hosted assets (generated from tinymce npm package via postinstall)
frontend/public/tinymce/

# Local archives accidentally created in the repo (e.g. backups, rar/zip exports)
frontend.rar
*.rar
*.zip
